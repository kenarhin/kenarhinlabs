{
  "name": "kenarhinlabs",
  "version": "0.0.1",
  "private": true,
  "description": "Ken Arhin Labs monorepo for the public site, admin app, API, shared packages, and project documentation.",
  "type": "module",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": "^11.10.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.10.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "check": "pnpm format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "list:workspaces": "pnpm --recursive list --depth -1"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "eslint-config-prettier": "^10.1.8"
  }
}
