{
  "name": "kenarhinlabs",
  "version": "0.0.1",
  "private": true,
  "description": "Ken Arhin Labs monorepo for the public site, admin app, API, shared packages, and project documentation.",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=11.10.0 <12.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "build:backend": "pnpm --filter ./apps/api --filter './packages/**' --filter '!@labs/design' --recursive --if-present run build",
    "check": "pnpm format:check && pnpm lint:backend && pnpm typecheck:backend && pnpm test:backend && pnpm build:backend",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --recursive --if-present run lint",
    "lint:backend": "eslint apps/api packages --ignore-pattern packages/design --max-warnings=0",
    "list:workspaces": "pnpm --recursive list --depth -1",
    "test": "pnpm --recursive --if-present run test",
    "test:backend": "pnpm --filter ./apps/api --filter './packages/**' --filter '!@labs/design' --recursive --if-present run test",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "typecheck:backend": "pnpm --filter ./apps/api --filter './packages/**' --filter '!@labs/design' --recursive --if-present run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "wrangler": "catalog:"
  }
}
