{
  "name": "@labs/pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./src/config/index.ts",
      "default": "./src/config/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./storage": {
      "types": "./src/storage/index.ts",
      "import": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./security": {
      "types": "./src/security/index.ts",
      "import": "./src/security/index.ts",
      "default": "./src/security/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p examples/tsconfig.json",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test"
  },
  "peerDependencies": {
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "astro": "^7.0.7",
    "fake-indexeddb": "^6.2.5",
    "react": "^19.2.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
