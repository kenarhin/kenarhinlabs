{
  "name": "@labs/design",
  "private": true,
  "version": "0.0.0",
  "description": "Shared brand tokens, fonts, themes, typesetting, and motion foundations for Ken Arhin Labs applications.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "style": "./src/styles/index.css",
