---
/**
 * Global public-site header with desktop and native-dialog mobile navigation.
 *
 * @param navigation Published or structural navigation items.
 * @param currentPath Current pathname used to expose aria-current.
 */
import type { NavigationItem } from "../../lib/api/public-api";
import { X } from "@lucide/astro";
import SiteLogo from "../common/SiteLogo.astro";
import ThemeMenu from "../common/ThemeMenu.astro";

interface Props {
  currentPath: string;
  navigation: NavigationItem[];
}

const { currentPath, navigation } = Astro.props;

/** Matches the current route while keeping homepage hash links inactive. */
function isCurrent(item: NavigationItem): boolean {
  if (item.href === "/") return currentPath === "/";
  if (item.href.includes("#")) return false;
  return currentPath === item.href || currentPath.startsWith(`${item.href}/`);
}
---

<header
  class="sticky top-0 z-40 border-b border-border/80 bg-background/94 backdrop-blur-sm"
  data-site-header
>
  <div
    class="mx-auto flex h-18 w-full max-w-wide items-center justify-between gap-3 px-page-mobile sm:px-page-tablet lg:h-20 lg:gap-6 lg:px-page-desktop"
  >
    <a
      href="/"
      class="inline-flex min-h-11 items-center rounded-xs"
      aria-label="Ken Arhin Labs — Home"
    >
      <SiteLogo class="w-36 sm:w-52" />
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary navigation">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrent(item) ? "page" : undefined}
            class="group relative py-3 text-body font-medium text-muted-foreground transition-colors duration-(--motion-duration-control) hover:text-foreground aria-[current=page]:text-foreground"
          >
            {item.label}
            <span class="absolute inset-x-0 bottom-1 h-px origin-left scale-x-0 bg-signal transition-transform duration-(--motion-duration-control) group-hover:scale-x-100 group-aria-[current=page]:scale-x-100" />
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <ThemeMenu />
      <a
        href="/start-a-project"
        class="inline-flex min-h-11 items-center justify-center rounded-sm bg-primary px-5 text-body-sm font-medium text-primary-foreground transition-transform duration-(--motion-duration-control) hover:-translate-y-0.5"
      >
        Start a project
      </a>
    </div>

    <button
      type="button"
      class="inline-flex size-11 items-center justify-center rounded-sm border border-border bg-surface text-foreground lg:hidden"
      aria-label="Open navigation"
      aria-controls="mobile-navigation"
      data-menu-open
    >
      <span class="sr-only">Open navigation</span>
      <span aria-hidden="true" class="grid gap-1.5">
        <span class="block h-px w-5 bg-current"></span>
        <span class="block h-px w-5 bg-current"></span>
      </span>
    </button>
  </div>

  <dialog
    id="mobile-navigation"
    class="m-0 h-dvh max-h-none w-full max-w-none bg-background p-0 text-foreground backdrop:bg-overlay lg:hidden"
    data-mobile-dialog
  >
    <div class="flex h-full flex-col px-page-mobile py-5 sm:px-page-tablet">
      <div class="flex items-center justify-between border-b border-border pb-5">
        <a href="/" aria-label="Ken Arhin Labs — Home" data-menu-link>
          <SiteLogo class="w-36 sm:w-44" />
        </a>
        <button
          type="button"
          class="inline-flex size-11 items-center justify-center rounded-sm border border-border bg-surface"
          aria-label="Close navigation"
          data-menu-close
        >
          <X class="size-5" aria-hidden="true" />
        </button>
      </div>

      <nav class="flex flex-1 flex-col justify-center" aria-label="Mobile navigation">
        <p class="mb-5 font-mono text-label uppercase tracking-widest text-muted-foreground">
          Navigate the system
        </p>
        <div class="grid">
          {
            navigation.map((item, index) => (
              <a
                href={item.href}
                data-menu-link
                class="flex min-h-16 items-center justify-between border-t border-border text-heading-sm text-foreground last:border-b"
              >
                <span>{item.label}</span>
                <span class="font-mono text-label text-muted-foreground">
                  {String(index + 1).padStart(2, "0")}
                </span>
              </a>
            ))
          }
        </div>
      </nav>

      <div class="grid gap-3 border-t border-border pt-5 sm:grid-cols-2 sm:items-end">
        <div class="[&>details]:w-full [&_summary]:w-full [&_summary]:justify-between">
          <ThemeMenu />
        </div>
        <a
          href="/start-a-project"
          data-menu-link
          class="inline-flex min-h-11 items-center justify-center rounded-sm bg-primary px-5 text-body-sm font-medium text-primary-foreground"
        >
          Start a project
        </a>
      </div>
    </div>
  </dialog>
</header>
