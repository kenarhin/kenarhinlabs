---
/**
 * Welcome.astro — temporary scaffold placeholder.
 *
 * Implements the full homepage messaging hierarchy:
 *   1. Brand/category label  — INDEPENDENT DIGITAL SYSTEMS LAB
 *   2. Hero H1               — Digital systems, built around people.
 *   3. Supporting copy       — concrete services the tagline intentionally omits
 *   4. Primary + secondary CTAs — Start a project / Explore our work
 *   5. Stack annotation      — IBM Plex Mono, technical notation style
 *
 * All classes resolve exclusively to @labs/design semantic tokens.
 * No raw colour values. Replace the shell of this file as real page
 * sections are built in later phases of the build plan.
 */
---

<section
  class="flex min-h-screen flex-col items-start justify-center bg-background px-page-mobile py-section sm:px-page-tablet lg:px-page-desktop"
>
  <!--
    Brand/category label — small technical annotation above the headline.
    IBM Plex Mono, uppercase, wide tracking. Mirrors the Living System
    diagram annotation style defined in DESIGN.md.
  -->
  <p
    class="mb-8 font-mono text-label uppercase tracking-widest text-muted-foreground"
  >
    INDEPENDENT DIGITAL SYSTEMS LAB
  </p>

  <!--
    Hero H1 — Bricolage Grotesque, tight tracking, large display size.
    This is the brand tagline. Line break is intentional: "Digital systems,"
    sits on its own line for editorial weight. Do not centre this heading.
  -->
  <h1 class="mb-6 max-w-4xl font-display text-display-lg text-foreground">
    Digital systems,<br />built around people.
  </h1>

  <!--
    Supporting copy — supplies the concrete services the tagline leaves out.
    IBM Plex Sans, lead size, muted so it does not compete with the H1.
  -->
  <p class="mb-12 max-w-2xl text-lead text-muted-foreground">
    Ken Arhin Labs designs, builds, hosts, and operates websites, applications,
    AI workflows, and digital infrastructure that work together.
  </p>

  <!-- Primary + secondary actions -->
  <div class="flex flex-wrap items-center gap-4">
    <!--
      Primary CTA — Signal Orange, destination-aware label.
      Height 48px matches the button-primary component spec from DESIGN.md.
    -->
    <a
      href="/contact"
      id="cta-start-project"
      class="inline-flex h-12 items-center gap-2 rounded-sm bg-primary px-6 text-body-sm font-medium text-primary-foreground transition-opacity duration-[--motion-duration-control] hover:opacity-90"
    >
      Start a project
    </a>

    <!--
      Secondary CTA — quieter, text-led. Outlined surface, destination-aware.
    -->
    <a
      href="/work"
      id="cta-explore-work"
      class="inline-flex h-12 items-center gap-2 rounded-sm border border-border bg-transparent px-6 text-body-sm font-medium text-foreground transition-colors duration-[--motion-duration-control] hover:bg-surface"
    >
      Explore our work
    </a>
  </div>

  <!--
    Stack annotation — IBM Plex Mono, technical notation.
    Field Green for LIVE status mirrors the operational/stable semantic role.
  -->
  <p class="mt-16 font-mono text-technical text-muted-foreground">
    STACK: ASTRO 7 · TAILWIND 4 · HONO · SUPABASE · CLOUDFLARE ·{" "}
    <span class="text-field">LIVE</span>
  </p>
</section>
