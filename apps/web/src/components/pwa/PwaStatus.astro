---
/**
 * Persistent, accessible PWA status surface.
 *
 * The registration module updates this element for offline readiness, network
 * loss, and prompt-based service-worker updates. It persists across Astro page
 * swaps so registration and event listeners remain single-instance.
 */
---

<aside
  id="pwa-status"
  class="fixed inset-x-4 bottom-4 z-50 hidden max-w-xl border border-border bg-surface p-4 text-foreground shadow-floating sm:left-auto sm:right-6 sm:w-[28rem]"
  role="status"
  aria-live="polite"
  transition:persist
  data-pwa-status
>
  <div class="flex items-start gap-4">
    <span class="mt-1 size-2 shrink-0 rounded-full bg-signal" aria-hidden="true"></span>
    <div class="min-w-0 flex-1">
      <p class="font-medium" data-pwa-message></p>
      <p class="mt-1 text-body-sm text-muted-foreground" data-pwa-detail></p>
      <div class="mt-3 hidden flex-wrap gap-2" data-pwa-actions>
        <button
          type="button"
          class="min-h-10 rounded-sm bg-primary px-4 text-body-sm font-medium text-primary-foreground"
          data-pwa-update
        >
          Update now
        </button>
        <button
          type="button"
          class="min-h-10 rounded-sm border border-border px-4 text-body-sm"
          data-pwa-dismiss
        >
          Later
        </button>
      </div>
    </div>
  </div>
</aside>
