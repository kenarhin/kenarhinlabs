---
/**
 * Public homepage foundation.
 *
 * The page uses approved brand copy and documented project names while the
 * backend homepage projection remains unavailable. It does not fabricate CMS
 * records, metrics, testimonials, or case-study outcomes.
 */
import LivingSystemHero from "../components/marketing/LivingSystemHero.astro";
import TechnologyRail from "../components/technology/TechnologyRail.astro";
import SelectedWork from "../components/work/SelectedWork.astro";
import Layout from "../layouts/Layout.astro";

const capabilities = [
  {
    id: "01",
    title: "Web platforms",
    description:
      "Editorial sites, product experiences, commerce, and operational interfaces designed as durable systems.",
    route: "STRATEGY → INTERFACE → ENGINEERING",
    layoutClass: "lg:col-span-2",
  },
  {
    id: "02",
    title: "Applications",
    description:
      "Purpose-built web and mobile products with clear workflows, resilient data, and maintainable foundations.",
    route: "PRODUCT → EXPERIENCE → RELEASE",
    layoutClass: "lg:col-span-2",
  },
  {
    id: "03",
    title: "AI + automation",
    description:
      "Useful agents and workflows connected to real business processes, review boundaries, and measurable actions.",
    route: "INPUT → REASONING → ACTION → REVIEW",
    layoutClass: "lg:col-span-2",
  },
  {
    id: "04",
    title: "Infrastructure",
    description:
      "Cloud architecture, domains, email, storage, security, and deployment pipelines assembled into one dependable foundation.",
    route: "ARCHITECT → PROVISION → SECURE → DEPLOY",
    layoutClass: "lg:col-span-3",
  },
  {
    id: "05",
    title: "Managed hosting + operations",
    description:
      "Websites, databases, applications, and AI agents kept available through established cloud platforms, with monitoring, maintenance, and accountable support.",
    route: "HOST → MONITOR → MAINTAIN → SCALE",
    note: "Managed on established platforms today. Our own hosting platform is planned.",
    layoutClass: "md:col-span-2 lg:col-span-3",
  },
];

---

<Layout
  title="Ken Arhin Labs | Digital Systems, AI & Web Platforms"
  description="Ken Arhin Labs designs, builds, hosts, and operates websites, applications, AI workflows, and digital infrastructure that work together."
>
  <div data-homepage>
    <LivingSystemHero />
    <TechnologyRail />
    <SelectedWork />

    <section
      id="capabilities"
      class="scroll-mt-24 px-page-mobile py-section sm:px-page-tablet lg:px-page-desktop lg:py-section-lg"
      aria-labelledby="capabilities-title"
    >
      <div class="mx-auto w-full max-w-wide">
        <div class="grid gap-8 border-t border-border pt-6 lg:grid-cols-12">
          <p
            class="font-mono text-label uppercase tracking-widest text-muted-foreground lg:col-span-3"
          >
            02 / Capabilities
          </p>
          <div class="lg:col-span-8 lg:col-start-5">
            <h2
              id="capabilities-title"
              class="max-w-4xl text-heading-lg text-foreground max-[272px]:text-[2.25rem]"
              data-section-reveal
            >
              What we design, build, and operate.
            </h2>
            <p class="mt-8 max-w-2xl text-lead text-muted-foreground">
              From public-facing platforms to the infrastructure behind them,
              each capability is designed as part of one coherent system.
            </p>
          </div>
        </div>

        <div class="mt-16 grid border-l border-t border-border md:grid-cols-2 lg:grid-cols-6">
          {
            capabilities.map((capability) => (
              <article
                class:list={[
                  "group min-h-80 min-w-0 border-b border-r border-border p-6 outline-none sm:p-8 lg:p-10",
                  capability.layoutClass,
                ]}
                tabindex="0"
                aria-labelledby={`capability-${capability.id}`}
                data-capability
              >
                <div class="flex items-start justify-between gap-6">
                  <span class="font-mono text-label text-muted-foreground">
                    {capability.id}
                  </span>
                  <span class="flex items-center" aria-hidden="true">
                    <span class="relative block h-px w-12 overflow-hidden bg-border sm:w-20">
                      <span class="absolute inset-0 origin-left scale-x-0 bg-signal transition-transform duration-(--motion-duration-layout) group-hover:scale-x-100 group-focus-within:scale-x-100" />
                    </span>
                    <span
                      class="size-3 rounded-full border border-border bg-surface transition-colors duration-(--motion-duration-control) group-hover:border-signal group-hover:bg-signal group-focus-within:border-signal group-focus-within:bg-signal"
                    />
                  </span>
                </div>
                <h3 id={`capability-${capability.id}`} class="mt-14 text-heading-sm text-foreground">
                  {capability.title}
                </h3>
                <p class="mt-5 max-w-lg text-body text-muted-foreground">
                  {capability.description}
                </p>
                <p class="mt-10 font-mono text-label tracking-wider text-system">
                  {capability.route}
                </p>
                {capability.note && (
                  <p class="mt-5 max-w-lg border-l border-signal pl-4 font-mono text-label leading-relaxed text-muted-foreground">
                    {capability.note}
                  </p>
                )}
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section
      id="approach"
      class="scroll-mt-24 bg-surface-strong px-page-mobile py-section text-surface-strong-foreground sm:px-page-tablet lg:px-page-desktop lg:py-section-lg"
      aria-labelledby="approach-title"
    >
      <div class="mx-auto w-full max-w-wide">
        <div class="grid gap-12 lg:grid-cols-12">
          <div class="min-w-0 lg:col-span-4">
            <p class="font-mono text-label uppercase tracking-widest opacity-60">
              03 / How the system comes together
            </p>
            <p class="mt-8 max-w-md text-body opacity-70">
              The shape changes with the problem. The operating discipline does
              not.
            </p>
          </div>
          <div class="min-w-0 lg:col-span-7 lg:col-start-6">
            <h2
              id="approach-title"
              class="text-heading-lg max-[272px]:text-[2.25rem]"
              data-section-reveal
            >
              A clear path from uncertainty to operation.
            </h2>
          </div>
        </div>

        <ol class="mt-20 grid border-l border-t border-white/20 sm:grid-cols-2 lg:grid-cols-5">
          {
            [
              ["01", "Discover", "Clarify the real problem, people, constraints, and evidence."],
              ["02", "Structure", "Map the experience, data, services, and operational boundaries."],
              ["03", "Build", "Design and engineer the smallest coherent system that solves it."],
              ["04", "Launch", "Validate, deploy, document, and make the change observable."],
              ["05", "Operate", "Improve the system with real usage, support, and measured learning."],
            ].map(([id, title, description]) => (
              <li class="min-h-64 border-b border-r border-white/20 p-6" data-process-step>
                <span class="font-mono text-label text-signal">{id}</span>
                <h3 class="mt-12 text-heading-sm">{title}</h3>
                <p class="mt-4 text-body-sm opacity-65">{description}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section
      class="px-page-mobile py-section sm:px-page-tablet lg:px-page-desktop lg:py-section-lg"
      aria-labelledby="next-system-title"
    >
      <div
        class="mx-auto grid w-full max-w-wide gap-12 border-t border-border pt-8 lg:grid-cols-12"
      >
        <p class="font-mono text-label uppercase tracking-widest text-muted-foreground lg:col-span-3">
          04 / Start somewhere useful
        </p>
        <div class="min-w-0 lg:col-span-8 lg:col-start-5">
          <h2
            id="next-system-title"
            class="text-heading-lg text-foreground max-[272px]:text-[2.25rem]"
            data-section-reveal
          >
            Bring us the messy version. We will help structure the system.
          </h2>
          <p class="mt-7 max-w-2xl text-lead text-muted-foreground">
            Whether you need a public platform, an internal workflow, an AI
            agent, or the infrastructure around it, the first step is a clear
            conversation.
          </p>
          <a
            href="/contact"
            class="mt-10 inline-flex min-h-12 items-center gap-5 rounded-sm bg-primary px-6 text-body-sm font-medium text-primary-foreground transition-transform duration-(--motion-duration-control) hover:-translate-y-1"
          >
            Start a project
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>
