---
/** Branded not-found route that remains useful without client JavaScript. */
import SiteLogo from "../components/common/SiteLogo.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page not found"
  description="The requested route is not part of the Ken Arhin Labs public system."
  noindex
>
  <section class="relative overflow-hidden px-page-mobile py-section sm:px-page-tablet lg:px-page-desktop lg:py-section-lg">
    <div class="mx-auto grid min-h-[62vh] w-full max-w-wide items-center gap-14 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="font-mono text-label uppercase tracking-widest text-signal">
          Error / 404 / Route unavailable
        </p>
        <h1 class="mt-8 text-display-lg text-foreground">
          This route does not connect to the current system.
        </h1>
        <p class="mt-8 max-w-2xl text-lead text-muted-foreground">
          The address may have changed, the page may not be published yet, or
          the route may have been entered incorrectly.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a class="inline-flex min-h-12 items-center rounded-sm bg-primary px-6 text-body-sm font-medium text-primary-foreground" href="/">
            Return home
          </a>
          <a class="inline-flex min-h-12 items-center rounded-sm border border-border bg-surface px-6 text-body-sm font-medium" href="/contact">
            Contact the lab
          </a>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-sm lg:col-span-4 lg:col-start-9" aria-hidden="true">
        <div class="absolute left-1/2 top-1/2 h-px w-[140%] -translate-x-1/2 -translate-y-1/2 -rotate-24 bg-border"></div>
        <div class="absolute left-1/2 top-1/2 h-px w-[140%] -translate-x-1/2 -translate-y-1/2 rotate-24 bg-border"></div>
        <div class="relative grid aspect-square place-items-center rounded-full border border-border bg-surface">
          <SiteLogo compact class="w-28 text-muted-foreground" />
          <span class="absolute right-[24%] top-[29%] size-4 rounded-full bg-signal"></span>
        </div>
      </div>
    </div>
  </section>
</Layout>
