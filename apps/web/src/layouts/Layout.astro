---
/**
 * BaseLayout.astro — root layout for all public site pages.
 *
 * Responsibilities:
 *   - HTML shell with correct lang, charset, and viewport
 *   - Themed html element: data-theme attribute set before first paint
 *     to prevent flash of wrong color scheme
 *   - Global CSS import (Tailwind v4 + @labs/design tokens)
 *   - SEO: page-level title, description, og:image with sensible defaults
 *   - Astro View Transitions (ClientRouter) for SPA-style navigation
 *   - Theme boot script: reads localStorage → sets data-theme before paint,
 *     re-applied on every astro:after-swap to prevent flash during navigation
 *   - Slot for page content
 *
 * Props:
 *   title       - Page <title>. Defaults to site name.
 *   description - Meta description. Defaults to site tagline.
 *   image       - og:image URL. Defaults to /og.png.
 *   noindex     - Set true to add <meta name="robots" content="noindex">.
 */

import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

/* Site-wide defaults. */
const SITE_NAME = "Ken Arhin Labs";
/**
 * SITE_TAGLINE is used as the default meta description for pages that do
 * not supply their own. It is also the H1 on the homepage.
 * The homepage <title> is set separately via a page-level prop to keep
 * it SEO-optimised (descriptive + keyword-rich) while the tagline remains
 * concise and human.
 */
const SITE_TAGLINE = "Digital systems, built around people.";
const SITE_META_DESC =
  "Ken Arhin Labs designs, builds, hosts, and operates websites, web applications, AI workflows, and connected digital systems for modern businesses.";
const SITE_URL = "https://kenarhinlabs.com";

const {
  title = SITE_NAME,
  /* Pages that don't pass a description get the full meta description. */
  description = SITE_META_DESC,
  image = "/og.png",
  noindex = false,
} = Astro.props;

/*
 * Compose the canonical <title>.
 * The homepage passes its own title already containing "Ken Arhin Labs"
 * so we use it verbatim. All other pages get "Page Name | Ken Arhin Labs".
 */
const pageTitle = title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, SITE_URL)} />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, SITE_URL)} />

    <!-- Astro generator tag (helps with debugging) -->
    <meta name="generator" content={Astro.generator} />

    <!--
      Theme boot script — MUST run inline before paint to avoid FOUC.
      Reads the stored preference from localStorage and sets data-theme on
      <html> immediately. If no preference is stored, the CSS media query
      in @labs/design/theme.css handles the system preference automatically
      (the :root:not([data-theme]) rule). We therefore only set the attribute
      when a preference has been explicitly chosen.

      is:inline forces Astro to leave this script unprocessed and inline it
      directly so it always executes at the correct time during SSR and also
      re-executes on every view transition via astro:after-swap.
    -->
    <script is:inline>
      (function () {
        /**
         * Applies the stored theme preference to the <html> element.
         * Called once on page load and again on every view transition.
         *
         * Theme values:
         *   "light"  → data-theme="light"
         *   "dark"   → data-theme="dark"
         *   "system" → data-theme attribute removed (CSS media query takes over)
         *   absent   → same as "system"
         */
        function applyTheme() {
          var stored;
          try {
            stored = localStorage.getItem("labs-theme");
          } catch (_) {
            /* localStorage blocked (private browsing, iframe sandbox, etc.) */
          }

          var html = document.documentElement;

          if (stored === "light" || stored === "dark") {
            html.setAttribute("data-theme", stored);
          } else {
            /* "system" or absent: remove the attribute so the CSS media query governs. */
            html.removeAttribute("data-theme");
          }
        }

        /* Apply immediately before first paint. */
        applyTheme();

        /* Re-apply after each Astro view transition to prevent flash on navigation. */
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>

    <!-- Astro View Transitions — SPA-style navigation with fallback. -->
    <ClientRouter />
  </head>

  <body>
    <!-- Page content injected here from individual .astro page files. -->
    <slot />
  </body>
</html>
