---
/**
 * Root document layout for every public route.
 *
 * @param title Human-readable page title without the global suffix.
 * @param description Search/social description.
 * @param image Absolute or site-relative Open Graph image.
 * @param noindex Prevents indexing for utility/error routes.
 * @param bodyClass Optional page-owned body composition class.
 */
import { ClientRouter } from "astro:transitions";
import PwaStatus from "../components/pwa/PwaStatus.astro";
import SiteFooter from "../components/navigation/SiteFooter.astro";
import SiteHeader from "../components/navigation/SiteHeader.astro";
import { getSiteNavigation } from "../lib/api/public-api";
import "../styles/global.css";

interface Props {
  bodyClass?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  title?: string;
}

const SITE_NAME = "Ken Arhin Labs";
const SITE_DESCRIPTION =
  "Ken Arhin Labs designs, builds, hosts, and operates websites, applications, AI workflows, and digital infrastructure that work together.";
const SITE_URL = "https://kenarhinlabs.com";

const {
  bodyClass = "",
  description = SITE_DESCRIPTION,
  image = "/social/default-og.png",
  noindex = false,
  title = SITE_NAME,
} = Astro.props;

const pageTitle =
  title === SITE_NAME || title.includes(SITE_NAME)
    ? title
    : `${title} | ${SITE_NAME}`;
const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
const socialImageURL = new URL(image, SITE_URL);
const navigation = await getSiteNavigation();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#11130F" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    <!--
      The synchronous theme boot runs before paint. Astro's before-swap hook
      applies the same preference to the incoming document during navigation.
    -->
    <script is:inline>
      (function () {
        var stored = null;
        try {
          stored = localStorage.getItem("labs-theme");
        } catch (_) {
          /* Storage can be blocked; system CSS remains the safe fallback. */
        }

        if (stored === "light" || stored === "dark") {
          document.documentElement.setAttribute("data-theme", stored);
        } else {
          document.documentElement.removeAttribute("data-theme");
        }
      })();
    </script>

    <ClientRouter fallback="swap" />
  </head>
  <body class={bodyClass}>
    <a
      href="#main-content"
      class="fixed left-4 top-4 z-[100] -translate-y-24 rounded-sm bg-primary px-4 py-3 font-medium text-primary-foreground transition-transform focus:translate-y-0"
    >
      Skip to content
    </a>

    <SiteHeader
      navigation={navigation.header}
      currentPath={Astro.url.pathname}
    />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <SiteFooter navigation={navigation.footer} />
    <PwaStatus />

    <script>
      import { installClientLifecycle } from "../lib/client/lifecycle";

      installClientLifecycle();
    </script>
  </body>
</html>
