# Public build-time configuration for the Astro site. Never place secrets here.
PUBLIC_API_BASE_URL=https://api.kenarhinlabs.com
PUBLIC_SITE_URL=https://kenarhinlabs.com
# Cloudflare's documented always-pass sitekey is suitable only for local development.
PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA
