{
  "name": "@labs/api",
  "version": "0.0.0",
  "private": true,
  "description": "The Hono API and domain boundary for Ken Arhin Labs.",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings --env-file .dev.vars.example",
    "cf-typegen:check": "wrangler types --env-interface CloudflareBindings --env-file .dev.vars.example --check",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@labs/auth": "workspace:^",
    "@labs/core": "workspace:^",
    "@labs/db": "workspace:^",
    "@labs/email": "workspace:^",
    "@labs/storage": "workspace:^",
    "@labs/sync": "workspace:^",
    "@labs/validators": "workspace:^",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
